# Copy to .env and fill in values.

# Database (existing)
# DATABASE_URL="postgresql://..."

# Escrow wallet: base58-encoded private key (64 bytes decoded).
# Generate with: solana-keygen new (then paste the secret key from the keypair file)
# Or export from Phantom: Settings → Security & Privacy → Export Private Key
ESCROW_PRIVATE_KEY="your_base58_private_key_here"

# Optional. Defaults to mainnet. For a dedicated RPC (Helius, QuickNode, etc.) set:
# SOLANA_RPC_URL="https://your-mainnet-rpc-url"
# For devnet testing only:
# SOLANA_RPC_URL="https://api.devnet.solana.com"
