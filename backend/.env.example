# Copy to .env and fill in values.

# Database. For Neon (including pooler), use sslmode=require and do NOT use channel_binding=require:
# DATABASE_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"
# (Node pg + Prisma adapter can fail with Neon pooler if channel_binding=require is set)

# Auth: set a long random string so tokens are signed/verified correctly. If missing, default is used (tokens from other envs will 401).
# JWT_SECRET="your_long_random_secret_here"

# Escrow wallet: base58-encoded private key (64 bytes decoded).
# Generate with: solana-keygen new (then paste the secret key from the keypair file)
# Or export from Phantom: Settings → Security & Privacy → Export Private Key
ESCROW_PRIVATE_KEY="your_base58_private_key_here"

# Optional. Defaults to mainnet. For a dedicated RPC (Helius, QuickNode, etc.) set:
# SOLANA_RPC_URL="https://your-mainnet-rpc-url"
# For devnet testing only:
# SOLANA_RPC_URL="https://api.devnet.solana.com"

# If you use nginx/reverse proxy: allow POST body and longer timeouts so create-task and confirm-stake work:
# client_max_body_size 1m; proxy_read_timeout 60s; proxy_connect_timeout 60s;
